# ============================================================
# JustTheBuilder — Environment Variables
# Copy this file to .env in the project root and fill in values
# ============================================================

# --- Discord ---
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id_here

# Your Discord user ID — required for /grant and /announce (owner-only; user-install commands)
# BOT_OWNER_ID=your_discord_user_id
BOT_OWNER_ID=your_discord_user_id_here

# --- AI (Groq — free at https://console.groq.com) ---
GROQ_API_KEY=your_groq_api_key_here
# Optional: override the default model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=mixtral-8x7b-32768

# --- Discord Monetization SKU IDs ---
# Basic Build Pack ($3.99 consumable) — one server build
PREMIUM_SKU_ID=1444371617319882863
# Pro Builder Subscription ($6.99/mo) — unlimited rebuilds + presets
# Pro subscription SKU (Discord test entitlements)
SUBSCRIPTION_SKU_ID=1444372305995104329

# Owner commands (/grant, /announce) use Discord "User Install" — they only show on YOUR account
# after you install JustTheBuilder to your user: Developer Portal → your app → Install Count →
# "Install to my account", or the app's profile → Add to My Apps. Set BOT_OWNER_ID to your user ID.

# --- Support Server ---
# Set this after building your support server with the bot
# SUPPORT_SERVER_INVITE=https://discord.gg/NEePze3rZd
# Guild ID of your support server — bot posts all usage logs to #staff-logs there
# SUPPORT_GUILD_ID=your_support_server_id
# Optional: exact channel ID instead of auto-finding #staff-logs
# STAFF_LOG_CHANNEL_ID=

# --- Optional ---
NODE_ENV=production
# DEBUG=1

# Bot ops channels (shared bot-test guild) — same IDs for all bots
OPS_GUILD_ID=1358552411718942913
OPS_ERROR_CHANNEL_ID=1525336364403658823
OPS_ANALYTICS_CHANNEL_ID=1525336362323279955
OPS_SUPPORT_CHANNEL_ID=1525863334845612136
OPS_ALERT_USER_ID=1153034319271559328
ALERTS_BOT_ID=justthebuilder
